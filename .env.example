# Render sets PORT automatically. Use this only for local testing if needed.
PORT=3000

# JSON-backed data file used by the current small friend-test deployment.
# On Render free tier, set this to /tmp/bababooey-arena-store.json.
# Warning: /tmp is ephemeral and can reset when the service restarts.
DATA_FILE=./data/dev-store.json

# Optional display hint used by humans/docs. The app does not require it yet.
PUBLIC_URL=http://localhost:3000
